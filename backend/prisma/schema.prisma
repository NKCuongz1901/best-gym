// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum Role {
  ADMIN
  USER
  PT
}

enum Gender {
  MALE
  FEMALE
}

enum FitnessGoal {
  LOSE_WEIGHT
  GAIN_MUSCLE
  IMPROVE_HEALTH
  MAINTAIN_WEIGHT
}

enum PackageUnit {
  DAY
  MONTH
}

enum UserPackageStatus {
  PENDING
  ACTIVE
  REJECTED
  EXPIRED
  CANCELLED
}

enum MuscleGroup {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  ABS
  FULL_BODY
}

enum ExerciseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProgramLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum PtAssistRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum WorkoutHistoryStatus {
  COMPLETED
  SKIPPED
}

enum SessionCompletion {
  COMPLETED
  PARTIAL
  NO_SHOW
}


enum ShiftType {
  MORNING   // 07:00-09:00
  AFTERNOON // 15:00-17:00
  EVENING   // 18:00-20:00
}

model Account {
  id                     String        @id @default(uuid())
  email                  String        @unique
  password               String
  status                 AccountStatus @default(INACTIVE)
  role                   Role          @default(USER)
  verificationCode       String?
  verificationCodeExpire DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  profile Profile?

  workoutHistories WorkoutHistory[]

  // 1) user mua gói
  userPackages UserPackage[] @relation("UserPackagesOwner")

  // 2) PT được gán cho gói
  ptAssignedUserPackages UserPackage[] @relation("UserPackagesPT")

  // check-in history
  checkins CheckIn[]

  // PT request: USER tạo request
  ptAssistRequests PtAssistRequest[] @relation("PtAssistRequestsOwner")

  // PT request: request gửi đến PT
  ptIncomingAssistRequests PtAssistRequest[] @relation("PtAssistRequestsPT")

  ptSessionReportsWritten  PtSessionReport[] @relation("PtSessionReportsPT")
  ptSessionReportsReceived PtSessionReport[] @relation("PtSessionReportsUser")

  /**
   * ✅ NEW: PT đăng ký ca làm việc theo range ngày + chi nhánh
   */
  ptShiftSchedules PtShiftSchedule[] @relation("PtShiftSchedulesPT")
}

model Profile {
  id        String  @id @default(uuid())
  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name        String?
  gender      Gender?
  phone       String?
  dateOfBirth DateTime?
  avatar      String?
  height      Float?
  weight      Float?
  fitnessGoal FitnessGoal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id       String  @id @default(uuid())
  name     String
  address  String?
  phone    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPackages     UserPackage[]
  checkins         CheckIn[]
  ptAssistRequests PtAssistRequest[]

  /**
   * ✅ NEW: Branch có nhiều ca PT đăng ký
   */
  ptShiftSchedules PtShiftSchedule[]
}

model Package {
  id            String     @id @default(uuid())
  name          String
  unit          PackageUnit
  durationValue Int
  hasPt         Boolean    @default(false)
  price         Int
  description   String?
  isActive      Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPackages UserPackage[]
}

model UserPackage {
  id String @id @default(uuid())

  // Owner of the user package
  accountId String
  account   Account @relation("UserPackagesOwner", fields: [accountId], references: [id], onDelete: Cascade)

  packageId String
  package   Package @relation(fields: [packageId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  // PT assigned to the user package (fixed PT)
  ptAccountId String?
  ptAccount   Account? @relation("UserPackagesPT", fields: [ptAccountId], references: [id])

  status UserPackageStatus @default(PENDING)

  startAt     DateTime?
  endAt       DateTime?
  activatedAt DateTime?
  cancelledAt DateTime?
  expiredAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkins         CheckIn[]
  ptAssistRequests PtAssistRequest[]

  programId String?
  program   Program? @relation(fields: [programId], references: [id])

  workoutHistories WorkoutHistory[]

  @@index([programId])
  @@index([accountId, status])
  @@index([ptAccountId])
  @@index([branchId])
}

model CheckIn {
  id String @id @default(uuid())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  userPackageId String
  userPackage   UserPackage @relation(fields: [userPackageId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  checkedInAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([accountId, checkedInAt])
  @@index([userPackageId, checkedInAt])
  @@index([branchId, checkedInAt])
}

model Exercise {
  id          String @id @default(uuid())
  name        String
  description String?
  content     String?

  muscleGroup MuscleGroup
  level       ExerciseLevel

  equipments String?
  thumbnail  String?
  videoUrl   String?

  suggestion String?
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programDayExercises ProgramDayExercise[]

  @@index([muscleGroup])
  @@index([level])
  @@index([isActive])
}

model Program {
  id          String       @id @default(uuid())
  name        String
  description String?
  level       ProgramLevel
  daysPerWeek Int
  isActive    Boolean      @default(true)

  thumbnail String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  days         ProgramDay[]
  userPackages UserPackage[]

  workoutHistories WorkoutHistory[]

  @@index([level])
  @@index([isActive])
}

model ProgramDay {
  id        String  @id @default(uuid())
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  title     String?
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises        ProgramDayExercise[]
  workoutHistories WorkoutHistory[]

  @@unique([programId, dayOfWeek])
  @@index([programId])
}

model ProgramDayExercise {
  id String @id @default(uuid())

  programDayId String
  programDay   ProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  sortOrder Int
  createdAt DateTime @default(now())

  @@unique([programDayId, exerciseId])
  @@index([exerciseId])
  @@index([programDayId, sortOrder])
}

model PtAssistRequest {
  id String @id @default(uuid())

  accountId String
  account   Account @relation("PtAssistRequestsOwner", fields: [accountId], references: [id], onDelete: Cascade)

  userPackageId String
  userPackage   UserPackage @relation(fields: [userPackageId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  ptAccountId String
  ptAccount   Account @relation("PtAssistRequestsPT", fields: [ptAccountId], references: [id], onDelete: Cascade)

  startTime DateTime
  endTime   DateTime

  status       PtAssistRequestStatus @default(PENDING)
  note         String?
  rejectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionReport PtSessionReport?

  @@index([ptAccountId, status])
  @@index([accountId, startTime])
  @@index([branchId, startTime])
  @@index([userPackageId, startTime])

  @@unique([accountId, ptAccountId, startTime, endTime])
}

model WorkoutHistory {
  id String @id @default(uuid())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  userPackageId String
  userPackage   UserPackage @relation(fields: [userPackageId], references: [id], onDelete: Cascade)

  programId String
  program   Program @relation(fields: [programId], references: [id])

  programDayId String
  programDay   ProgramDay @relation(fields: [programDayId], references: [id])

  workoutAt DateTime @default(now())

  status WorkoutHistoryStatus @default(COMPLETED)
  note   String?

  createdAt DateTime @default(now())

  @@index([accountId, workoutAt])
  @@index([userPackageId, workoutAt])
  @@index([programId, workoutAt])
  @@index([programDayId, workoutAt])

  @@unique([accountId, programDayId, workoutAt])
}

model PtSessionReport {
  id String @id @default(uuid())

  ptAssistRequestId String @unique
  ptAssistRequest   PtAssistRequest @relation(fields: [ptAssistRequestId], references: [id], onDelete: Cascade)

  ptAccountId String
  ptAccount   Account @relation("PtSessionReportsPT", fields: [ptAccountId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation("PtSessionReportsUser", fields: [accountId], references: [id], onDelete: Cascade)

  completion SessionCompletion @default(COMPLETED)

  summary         String?
  techniqueNote   String?
  improvement     String?
  nextSessionPlan String?

  weightKg Float?
  bodyNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ptAccountId, createdAt])
  @@index([accountId, createdAt])
}

/**
 * NEW: 3 shift templates (seed 3 rows)
 */
model PtShiftTemplate {
  id        String    @id @default(uuid())
  type      ShiftType @unique
  startTime String   
  endTime   String    
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules PtShiftSchedule[]
}


model PtShiftSchedule {
  id              String @id @default(uuid())

  ptAccountId     String
  ptAccount       Account @relation("PtShiftSchedulesPT", fields: [ptAccountId], references: [id], onDelete: Cascade)

  branchId        String
  branch          Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  shiftTemplateId String
  shiftTemplate   PtShiftTemplate @relation(fields: [shiftTemplateId], references: [id])

  fromDate    DateTime
  toDate      DateTime

  maxStudents Int     @default(1)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ptAccountId, branchId])
  @@index([shiftTemplateId])
  @@index([ptAccountId, fromDate, toDate])
  @@index([branchId, fromDate, toDate])
}