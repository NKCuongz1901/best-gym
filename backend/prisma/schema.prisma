// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum Role {
  ADMIN
  USER
  PT
}

enum Gender {
  MALE
  FEMALE
}

enum FitnessGoal {
  LOSE_WEIGHT
  GAIN_MUSCLE
  IMPROVE_HEALTH
  MAINTAIN_WEIGHT
}

enum PackageUnit {
  DAY
  MONTH
}

enum UserPackageStatus {
  PENDING   
  ACTIVE
  REJECTED 
  EXPIRED
  CANCELLED
}


model Account {
  id String @id @default(uuid())
  email String @unique
  password String
  status AccountStatus @default(INACTIVE)
  role Role @default(USER)
  verificationCode String?
  verificationCodeExpire DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile Profile?
  
  // 1) user mua gói
  userPackages UserPackage[] @relation("UserPackagesOwner")

  // 2) PT được gán cho gói
  ptAssignedUserPackages UserPackage[] @relation("UserPackagesPT")
  checkins CheckIn[]

}

model Profile {
  id String @id @default(uuid())
  accountId   String      @unique
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name String?
  gender Gender?
  phone String?
  dateOfBirth DateTime?
  avatar String?
  height Float?
  weight Float?
  fitnessGoal FitnessGoal?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id String @id @default(uuid())
  name String
  address String?
  phone String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userPackages UserPackage[]
  checkins CheckIn[]
}

model Package {
  id            String   @id @default(uuid())
  name          String
  unit          PackageUnit
  durationValue Int       
  hasPt         Boolean    @default(false) 
  price         Int
  description   String?
  isActive      Boolean    @default(true)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userPackages  UserPackage[]
}

model UserPackage {
  id           String @id @default(uuid())

  // Owner of the user package
  accountId    String
  account   Account @relation("UserPackagesOwner", fields: [accountId], references: [id], onDelete: Cascade)

  packageId    String
  package      Package @relation(fields: [packageId], references: [id])

  branchId     String
  branch       Branch  @relation(fields: [branchId], references: [id])

  // PT assigned to the user package
  ptAccountId  String?
  ptAccount   Account? @relation("UserPackagesPT", fields: [ptAccountId], references: [id])

  status       UserPackageStatus @default(PENDING)

  startAt      DateTime?
  endAt        DateTime?
  activatedAt  DateTime?
  cancelledAt  DateTime?
  expiredAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  checkins CheckIn[]


  @@index([accountId, status])
  @@index([ptAccountId])
  @@index([branchId])
}

model CheckIn {
  id            String   @id @default(uuid())

  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  userPackageId String
  userPackage   UserPackage @relation(fields: [userPackageId], references: [id], onDelete: Cascade)

  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  checkedInAt   DateTime @default(now())


  createdAt     DateTime @default(now())

  @@index([accountId, checkedInAt])
  @@index([userPackageId, checkedInAt])
  @@index([branchId, checkedInAt])
}